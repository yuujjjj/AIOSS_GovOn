# GovOn Environment Variables Example

# API Key for Authentication (Optional)
API_KEY=your_secret_api_key_here

# Model Configuration
MODEL_PATH=umyunsang/GovOn-EXAONE-LoRA-v2
GPU_UTILIZATION=0.8
MAX_MODEL_LEN=8192

# Data Paths
DATA_PATH=/app/data/processed/v2_train.jsonl
INDEX_PATH=/app/models/faiss_index/complaints.index
FAISS_INDEX_DIR=/app/models/faiss_index
BM25_INDEX_DIR=/app/models/bm25_index

# Search Configuration
BM25_INDEX_HMAC_KEY=your_hmac_key_for_bm25_integrity

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 공공데이터포털 민원 분석 API 키 (https://www.data.go.kr)
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# LangGraph 모델 어댑터 (vLLM OpenAI-compatible endpoint)
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY
