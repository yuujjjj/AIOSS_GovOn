# =============================================================================
# GovOn Runtime — 폐쇄망(에어갭) 설치 프로필 (.env.airgap)
# =============================================================================
# 사용법: cp .env.airgap.example .env
# 주의: compose가 이 파일을 컨테이너 환경변수로 주입하므로,
#       경로는 호스트가 아니라 컨테이너 내부 경로(`/app/...`) 기준으로 적습니다.

# --- 서빙 프로필 ---
SERVING_PROFILE=airgap

# --- 서버 ---
HOST=0.0.0.0
PORT=8000
HOST_PORT=8000
LOG_LEVEL=INFO
RELOAD=false

# --- 모델 (컨테이너 내부 경로 기준) ---
MODEL_PATH=/app/models/GovOn-EXAONE-AWQ-v2
GPU_UTILIZATION=0.8
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false
TRUST_REMOTE_CODE=true

# --- 데이터 경로 (컨테이너 내부 경로 기준) ---
DATA_PATH=/app/data/processed/v2_train.jsonl
INDEX_PATH=/app/models/faiss_index/complaints.index
FAISS_INDEX_DIR=/app/models/faiss_index
BM25_INDEX_DIR=/app/models/bm25_index
AGENTS_DIR=/app/agents

# --- 로그 / 캐시 ---
LOG_DIR=/var/log/govon
CACHE_DIR=/app/.cache

# --- 보안 (필수) ---
# 배포 전에 반드시 고유한 임의 문자열로 교체하세요.
API_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY
CORS_ORIGINS=http://10.0.0.100:3000

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true

# --- 타임아웃 ---
REQUEST_TIMEOUT_SEC=90

# --- Generation Defaults ---
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1

# --- Feature Flags ---
USE_RAG_PIPELINE=true
MODEL_VERSION=v2_lora

# --- LangGraph 모델 어댑터 ---
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY

# --- 검색 인덱스 무결성 (필수) ---
# 배포 전에 반드시 고유한 임의 문자열로 교체하세요.
BM25_INDEX_HMAC_KEY=CHANGE_ME_TO_SECURE_HMAC_KEY

# --- 헬스체크 ---
HEALTH_INTERVAL_SEC=30
HEALTH_TIMEOUT_SEC=10

# --- 폐쇄망 전용 설정 ---
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
