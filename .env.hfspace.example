# HuggingFace Spaces 배포용 환경변수
SERVING_PROFILE=container
HOST=0.0.0.0
PORT=7860
MODEL_PATH=LGAI-EXAONE/EXAONE-4.0-32B-AWQ
TRUST_REMOTE_CODE=true
MODEL_DTYPE=half
ENFORCE_EAGER=true
GPU_UTILIZATION=0.90
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false
# 개발/테스트용 와일드카드. 프로덕션에서는 특정 도메인으로 제한 필요
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
REQUEST_TIMEOUT_SEC=120
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:7860/v1
LANGGRAPH_MODEL_API_KEY=EMPTY
# HF Spaces Secrets로 설정할 것:
# HF_TOKEN=hf_...
# API_KEY=your-api-key
