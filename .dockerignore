# =============================================================================
# .dockerignore — GovOn Docker 빌드 시 제외할 파일/디렉토리
# =============================================================================

# ---------------------------------------------------------------------------
# Version control & CI/CD
# ---------------------------------------------------------------------------
.git/
.github/
.gitignore

# ---------------------------------------------------------------------------
# Claude / AI tooling
# ---------------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------------
# Tests (런타임에 불필요)
# ---------------------------------------------------------------------------
tests/

# ---------------------------------------------------------------------------
# Data & Models (Docker 볼륨으로 마운트)
# ---------------------------------------------------------------------------
data/
models/

# ---------------------------------------------------------------------------
# Documentation & static assets
# ---------------------------------------------------------------------------
docs/
assets/
notebooks/

# ---------------------------------------------------------------------------
# Python artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/

# ---------------------------------------------------------------------------
# Metrics & logs
# ---------------------------------------------------------------------------
metrics/
*.log

# ---------------------------------------------------------------------------
# Environment / secrets (보안 위험 — 절대 이미지에 포함 금지)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Archives & large binaries
# ---------------------------------------------------------------------------
*.tar.gz
*.zip

# ---------------------------------------------------------------------------
# IDE & OS
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Test / coverage caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
